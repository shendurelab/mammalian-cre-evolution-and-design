# this rule generates bam files for each cluster at each replicate
rule generate_coarse_replicate_bams:
    input:
        bam=BAM_PATH + '/EBD21_crispri_{replicate}.bam',        
    output:
        cell_bam = temp(BASE_PATH + '/{cluster}_{replicate}.bam')
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_cell_replicate_bams", 
        run_time="48:00:00", cores="4", memory="4", job_name="make_bam_{cluster}_{replicate}"
    threads: 4
    shell:
        """
        awk '(NR>1)' {BC_FILE} | grep 'fragments_{wildcards.replicate}' | grep -w '{wildcards.cluster}' | awk -v FS="\t" -v OFS="\t" '{{split($1,a,/#/); print a[2]}}' > {wildcards.cluster}_{wildcards.replicate}_BC.tmp ;
        
        {SUBSET_BAM_TOOL} -b {input.bam} --cell-barcodes {wildcards.cluster}_{wildcards.replicate}_BC.tmp --cores {params.cores} -o {output.cell_bam} ;
        rm {wildcards.cluster}_{wildcards.replicate}_BC.tmp ;
        """

# this rule merge bam files for each cluster
rule generate_merge_coarse_bams:
    input:
        bam_files = expand(BASE_PATH + "/{{cluster}}_{replicate}.bam",replicate = replicates)       
    output:
        cell_bam = BASE_PATH + '/{cluster}.sorted.bam'
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_merge_coarse_bams", 
        run_time="48:00:00", cores="4", memory="4", job_name="merge_{cluster}_bams"
    threads: 4
    shell:
        """
        samtools merge -@{params.cores} -f {wildcards.cluster}.merged_unsorted.bam {input.bam_files} ;
        samtools sort -@{params.cores} {wildcards.cluster}.merged_unsorted.bam -o {output.cell_bam} ; 
        samtools index {output.cell_bam} ; 
        rm {wildcards.cluster}.merged_unsorted.bam ; 
        """
        
## this rule generates blacklist for filter
rule generate_mouse_blacklist:
    input:
        blacklist = "/net/shendure/vol10/projects/tli/nobackup/enhancer_project/metadata/Blacklist/lists/Blacklist_v2/mm10-blacklist.v2.bed",
        chromsizes = '/net/gs/vol1/home/tli824/bin/references/mouse/UCSC/mm10/mm10.chrom.sizes'
    output:
        blacklist_extended = BASE_PATH + '/mm10-blacklist.chrombpnet.bed',
        subset_chromsizes = BASE_PATH + '/mm10.subset.sizes', 
        fold_json = BASE_PATH + '/splits/fold_0.json'
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_mouse_blacklist", 
        run_time="48:00:00", cores="1", memory="4", job_name="generate_mouse_blacklist"
    threads: 1
    shell:
        """
        source activate chrombpnet ;
        bedtools slop -i {input.blacklist} -g {input.chromsizes} -b 1057 >  {output.blacklist_extended} ;
        grep 'chr' {input.chromsizes} | sort | grep -F -v 'random' | grep -F -v 'chrUn' | grep -F -v 'chrM' > {output.subset_chromsizes} ;
        mkdir -p splits ;
        chrombpnet prep splits -c {output.subset_chromsizes} -tcr chr1 chr4 chr6 -vcr chr10 chr17 -op splits/fold_0 ;
        """
        
    
# this rule does peak calling
rule generate_coarse_peak_calling:
    input:
        cell_bam = BASE_PATH + '/{cluster}.sorted.bam',
    output:
        peaks = BASE_PATH + '/macs2/{cluster}_peaks.narrowPeak',
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_coarse_peak_calling", 
        run_time="48:00:00", cores="4", memory="4", job_name="callpeaks_{cluster}"
    threads: 4
    shell:
        """        
        macs2 callpeak -t {input.cell_bam} -f BAM -n {wildcards.cluster} --outdir macs2 --shift -100 --extsize 200 -p 0.01 -g 1.87e9;
        """

# this rule does overlapping peak file
rule generate_overlaps_peaks:
    input:
        expand(BASE_PATH + '/macs2/{cluster}_peaks.narrowPeak', cluster = coarse_clusters)
    output:
        final_peaks = BASE_PATH + '/macs2/overlaps/overlap.peaks.resolved.500.bed',
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_overlaps_peaks", 
        run_time="48:00:00", cores="1", memory="4", job_name="generate_overlaps_peaks"
    threads: 1
    shell:
        """
        mkdir -p {BASE_PATH}/macs2/overlaps ;
        cd {BASE_PATH}/macs2/overlaps ;
        cat {input} | sort -k9 -nr | gzip > overlap.peaks.qval.sort.narrowPeak.gz ;
        zcat overlap.peaks.qval.sort.narrowPeak.gz | awk -v OFS='\t' '{{print $1,$2+$10-250,$2+$10+250}}' | bedsort | bedtools merge > overlap.peaks.merged.bed ;
        ### resolve peaks
        python {BASE_PATH}/resolve.py -np overlap.peaks.qval.sort.narrowPeak.gz -o {output.final_peaks} ;
        """


# this rule cleans peaks for blacklist overlaps, and generates bg sets for each cluster
rule generate_clean_peaks:
    input:
        peaks = BASE_PATH + '/macs2/{cluster}_peaks.narrowPeak',
        blacklist = "/net/shendure/vol10/projects/tli/nobackup/enhancer_project/metadata/Blacklist/lists/Blacklist_v2/mm10-blacklist.v2.bed",
        blacklist_extended = BASE_PATH + '/mm10-blacklist.chrombpnet.bed',
        chromsizes = '/net/gs/vol1/home/tli824/bin/references/mouse/UCSC/mm10/mm10.chrom.sizes',
        genome = '/net/gs/vol1/home/tli824/bin/references/mouse/UCSC/mm10/mm10.fa',
        fold_json = BASE_PATH + '/splits/fold_0.json'
    output:
        clean_peaks = BASE_PATH + '/input_peaks/{cluster}_peaks_no_blacklist.bed',
        bg_set = BASE_PATH + '/background_sets/{cluster}_negatives.bed'
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_clean_peaks", 
        run_time="48:00:00", cores="4", memory="4", job_name="cleanpeaks_{cluster}"
    threads: 4
    shell:
        """
        source activate chrombpnet ;
        
        mkdir -p {BASE_PATH}/input_peaks ;
        cd {BASE_PATH}/input_peaks ;
        bedtools intersect -v -a {input.peaks} -b {input.blacklist_extended}  > {wildcards.cluster}.tmp ;
        ### remove peaks that are tested from JB's MPRA set
        bedtools intersect -v -a {wildcards.cluster}.tmp -b {TESTED_MPRA_BED} > {output.clean_peaks} ;
        rm {wildcards.cluster}.tmp ;
        
        mkdir -p {BASE_PATH}/background_sets ;
        cd {BASE_PATH}/background_sets ;
        chrombpnet prep nonpeaks -g {input.genome} -p {output.clean_peaks} -c {input.chromsizes} -fl {input.fold_json} -br {input.blacklist} -o {BASE_PATH}/background_sets/{wildcards.cluster} ; 
        """

### make prediction bed file
rule generate_pred_file:
    input:
        chromsizes = '/net/gs/vol1/home/tli824/bin/references/mouse/UCSC/mm10/mm10.chrom.sizes'
    output:
        pred_bed = temp(BASE_PATH + '/heldout_set.bed')
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_pred_file", 
        run_time="48:00:00", cores="1", memory="4", job_name="generate_pred_file"
    threads: 1
    shell:
        """ 
        bedtools makewindows -b <( bedtools slop -i {GENE_BED} -g {input.chromsizes} -b 200000 ) -w 800 -i srcwinnum > gene_body_windows.bed;
        awk -v FS="\t" -v OFS="\t" '{{print $1,$2,$3,$4,".",".",".",".",".","1057"}}' gene_body_windows.bed > {output.pred_bed} ;
        rm gene_body_windows.bed ;
        """
        
        
