rule generate_chrombpnet_TSSpredictions:
    input:
        tss_bed = '/net/shendure/vol10/projects/tli/nobackup/EB_dev_project/data/mTSS_bed_file_20220710.adjusted.bed',
        bias_model = BASE_PATH + '/bias_models/{cluster}/models/{cluster}_bias.h5',
        chrom_model = BASE_PATH + '/chrombpnet_models/{cluster}/models/chrombpnet.h5',
        chrom_nobias_model = BASE_PATH + '/chrombpnet_models/{cluster}/models/chrombpnet_nobias.h5',
        subset_chromsizes = BASE_PATH + '/mm10.subset.sizes',
        genome = '/net/gs/vol1/home/tli824/bin/references/mouse/UCSC/mm10/mm10.fa',
        bigwig = BASE_PATH + '/scATAC_bigwigs/{cluster}-TileSize-50-normMethod-ReadsInTSS-ArchR.bw'
    output:
        bw = BASE_PATH + '/tss_predictions/{cluster}/{cluster}_chrombpnet_nobias.bw',
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_chrombpnet_TSSpredictions", 
        run_time="48:00:00", cores="1", memory="64", job_name="cmb_TSSpredict_{cluster}"
    threads: 1
    shell:
        """
        source activate chrombpnet ;
        
        mkdir -p {BASE_PATH}/tss_predictions/{wildcards.cluster} ;
        cd {BASE_PATH}/tss_predictions/{wildcards.cluster} ;
        
        awk -v FS="\t" -v OFS="\t" '{{print $1,$2,$3,$4,".",".",".",".",".","1057"}}' {input.tss_bed} > {wildcards.cluster}.tmp.bed ;
        
        chrombpnet pred_bw \
        -r {wildcards.cluster}.tmp.bed  \
        -g {input.genome} \
        -c {input.subset_chromsizes} \
        -bm {input.bias_model} \
        -cm {input.chrom_model} \
        -cmb {input.chrom_nobias_model} \
        -op {BASE_PATH}/heldout_predictions/{wildcards.cluster}/{wildcards.cluster} ;
        
        awk -v FS="\t" -v OFS="\t" '{{print $1,$2,$3,$4"|"NR}}' {input.tss_bed} > {wildcards.cluster}.tmp.bed ;
        {KENT_UTILS}/bigWigAverageOverBed -bedOut={wildcards.cluster}_nobias_TSSprediction.bed {output.bw} {wildcards.cluster}.tmp.bed /dev/null ;
        rm {wildcards.cluster}.tmp.bed ;
        """

rule score_heldout:
    input:
        bw = BASE_PATH + '/heldout_predictions/{cluster}/{cluster}_chrombpnet_nobias.bw',
        pred_bed = BASE_PATH + '/heldout_set.bed'
    output:
        pred_acc=BASE_PATH + '/heldout_predictions/{cluster}/{cluster}_pred.bed'
    params:
        error_out_file=BASE_PATH + "/slurm_files/score_heldout", 
        run_time="48:00:00", cores="1", memory="64", job_name="score_heldout_{cluster}"
    threads: 1
    shell:
        """
        {KENT_UTILS}/bigWigAverageOverBed -bedOut={output.pred_acc} {input.bw} <( awk -v FS="\t" -v OFS="\t" '{{print $1,$2,$3,$4}}' {input.pred_bed} ) /dev/null ;
        """

rule generate_chrombpnet_contrib_score:
    input:
        chrom_nobias_model = BASE_PATH + '/chrombpnet_models/{cluster}/models/chrombpnet_nobias.h5',
        chromsizes = '/net/gs/vol1/home/tli824/bin/references/mouse/UCSC/mm10/mm10.chrom.sizes',
        genome = '/net/gs/vol1/home/tli824/bin/references/mouse/UCSC/mm10/mm10.fa',
    output:
        contrib_score = BASE_PATH + '/contrib_scores/{cluster}.profile_scores.h5',
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_chrombpnet_contrib_score", 
        run_time="999:00:00", cores="1", memory="64", job_name="cmb_scoreSeq_{cluster}"
    threads: 1
    shell:
        """
        source activate chrombpnet ;
        
        mkdir -p {BASE_PATH}/contrib_scores/ ;
        cd {BASE_PATH}/contrib_scores/ ;
        grep '{wildcards.cluster}' {TESTED_MPRA_BED} | awk -v FS="\t" -v OFS="\t" '{{print $1,$2,$3,$4,".",".",".",".",".","1057"}}' > {wildcards.cluster}_contrib_input.bed ;
        
        chrombpnet contribs_bw \
        -r {wildcards.cluster}_contrib_input.bed  \
        -g {input.genome} \
        -c {input.chromsizes} \
        -m {input.chrom_nobias_model} \
        -op {BASE_PATH}/contrib_scores/{wildcards.cluster} ;
        
        rm {wildcards.cluster}_contrib_input.bed ;
        """
        
rule generate_denovo_motif_discovery:
    input:
        contrib_score = BASE_PATH + '/contrib_scores/{cluster}.profile_scores.h5',
    output:
        bw = BASE_PATH + '/tf_modisico/{cluster}_modisco.h5',
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_denovo_motif_discovery", 
        run_time="120:00:00", cores="1", memory="64", job_name="tfmodisico_{cluster}"
    threads: 1
    shell:
        """
        source activate chrombpnet ;
        
        mkdir -p {BASE_PATH}/tf_modisico/ ;
        
        chrombpnet modisco_motifs \
        -i {input.contrib_score}  \
        -n 50000 \
        -op {BASE_PATH}/tf_modisico/{wildcards.cluster} ;
        """
        
rule generate_tf_footprinting:
    input:
        chrom_nobias_model = BASE_PATH + '/chrombpnet_models/{cluster}/models/chrombpnet_nobias.h5',
        chromsizes = '/net/gs/vol1/home/tli824/bin/references/mouse/UCSC/mm10/mm10.chrom.sizes',
        genome = '/net/gs/vol1/home/tli824/bin/references/mouse/UCSC/mm10/mm10.fa',
        motifs=BASE_PATH + "/EBmotif_to_pwm.TF.tsv",
        bg_set = BASE_PATH + '/background_sets/{cluster}_negatives.bed',
        fold_json = BASE_PATH + '/splits/fold_0.json'
    output:
        fp = BASE_PATH + '/tf_footprints/{cluster}/{cluster}_footprints.h5',
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_tf_footprinting", 
        run_time="120:00:00", cores="1", memory="100", job_name="TF_FP_{cluster}"
    threads: 1
    shell:
        """
        source activate chrombpnet ;
        
        mkdir -p {BASE_PATH}/tf_footprints/{wildcards.cluster} ;
        cd {BASE_PATH}/tf_footprints/{wildcards.cluster} ;
        shuf -n 30000 {input.bg_set} > {wildcards.cluster}_negatives_subset30k.bed ;
        
        chrombpnet footprints \
            -r {wildcards.cluster}_negatives_subset30k.bed  \
            -m {input.chrom_nobias_model} \
            -g {input.genome} \
            -fl {input.fold_json} \
            -op {BASE_PATH}/tf_footprints/{wildcards.cluster}/{wildcards.cluster} \
            -pwm_f {input.motifs}
        
        python {BASE_PATH}/realign_footprints.py --h5_file {output.fp} -op {wildcards.cluster} ;
        
        rm {wildcards.cluster}_negatives_subset30k.bed ;
        """
