bc_df = bc_df[bc_df['coarse_cluster'] != 'TBD']
# gets available cell types and sorts for consistency
coarse_clusters = bc_df['coarse_cluster'].unique()
defined_clusters = bc_df['refined_cluster'].unique()
bc_df[['replicate','barcode']] = bc_df['cellBC'].str.split('#',expand=True)
bc_df[['frag','replicate']] = bc_df['replicate'].str.split('_',expand=True)
replicates = bc_df['replicate'].unique()

