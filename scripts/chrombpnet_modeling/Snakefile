### the big daddy prediction ~ probably run on gpus if you can
rule generate_chrombpnet_predict_all:
    input:
        peaks = BASE_PATH + '/macs2/{cluster}_peaks.narrowPeak',
        bg_set = BASE_PATH + '/background_sets/{cluster}_negatives.bed',
        bias_model = BASE_PATH + '/bias_models/{cluster}/models/{cluster}_bias.h5',
        chrom_model = BASE_PATH + '/chrombpnet_models/{cluster}/models/chrombpnet.h5',
        chrom_nobias_model = BASE_PATH + '/chrombpnet_models/{cluster}/models/chrombpnet_nobias.h5',
        chromsizes = '/net/gs/vol1/home/tli824/bin/references/mouse/UCSC/mm10/mm10.chrom.sizes',
        genome = '/net/gs/vol1/home/tli824/bin/references/mouse/UCSC/mm10/mm10.fa',
        bigwig = BASE_PATH + '/scATAC_bigwigs/{cluster}-TileSize-50-normMethod-ReadsInTSS-ArchR.bw'
    output:
        bw = BASE_PATH + '/all_predictions/{cluster}/{cluster}_chrombpnet_nobias.bw',
    params:
        error_out_file=BASE_PATH + "/slurm_files/generate_chrombpnet_predict_all", 
        run_time="120:00:00", cores="1", memory="100", job_name="cmb_predict_all_{cluster}"
    threads: 1
    shell:
        """
        source activate chrombpnet ;
        
        mkdir -p {BASE_PATH}/all_predictions/{wildcards.cluster} ;
        cd {BASE_PATH}/all_predictions/{wildcards.cluster} ;
        cat {input.peaks} {input.bg_set} > {wildcards.cluster}_pred_set.bed ;
        
        chrombpnet pred_bw \
        -r {wildcards.cluster}_pred_set.bed  \
        -g {input.genome} \
        -c {input.chromsizes} \
        -bm {input.bias_model} \
        -cm {input.chrom_model} \
        -cmb {input.chrom_nobias_model} \
        -bw {input.bigwig} \
        -op {BASE_PATH}/all_predictions/{wildcards.cluster}/{wildcards.cluster} ;
        """


